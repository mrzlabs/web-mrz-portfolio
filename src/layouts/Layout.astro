---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Andres Martinez | Soluciones corporativas y crecimiento digital',
  description = 'Portafolio de Andres Martinez: desarrollo web, automatizacion, datos, arquitectura operativa y crecimiento digital.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --bg: #f5efe2;
    --ink: #171717;
    --muted: #5f6470;
    --line: #d9d3c8;
    --panel: #fffdf8;
    --blue: #1f5eff;
    --green: #1b7f5a;
    --amber: #b96f16;
    --red: #a33a2a;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-width: 320px;
    background: var(--bg);
    color: var(--ink);
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  a {
    color: inherit;
  }

  img {
    display: block;
    max-width: 100%;
  }
</style>
