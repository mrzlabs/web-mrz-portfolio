---
// Starfield background component
---

<div class="starfield" aria-hidden="true">
  <svg class="stars-canvas" viewBox="0 0 1000 600" preserveAspectRatio="xMidYMid slice">
    <!-- Glow orbs -->
    <circle cx="100" cy="80" r="3" fill="rgba(192, 132, 252, 0.8)" />
    <circle cx="250" cy="120" r="2" fill="rgba(139, 92, 246, 0.6)" />
    <circle cx="450" cy="60" r="3.5" fill="rgba(168, 85, 247, 0.7)" />
    <circle cx="650" cy="150" r="2" fill="rgba(99, 102, 241, 0.5)" />
    <circle cx="820" cy="90" r="2.5" fill="rgba(216, 180, 254, 0.6)" />
    <circle cx="150" cy="300" r="2" fill="rgba(129, 140, 248, 0.5)" />
    <circle cx="500" cy="400" r="2.5" fill="rgba(192, 132, 252, 0.7)" />
    <circle cx="750" cy="350" r="2" fill="rgba(168, 85, 247, 0.5)" />
    <circle cx="900" cy="500" r="3" fill="rgba(139, 92, 246, 0.6)" />
    <circle cx="300" cy="550" r="2" fill="rgba(216, 180, 254, 0.5)" />
    <!-- Más puntos de luz -->
    <circle cx="50" cy="200" r="1.5" fill="rgba(255, 255, 255, 0.4)" />
    <circle cx="200" cy="450" r="1" fill="rgba(255, 255, 255, 0.3)" />
    <circle cx="600" cy="300" r="1.5" fill="rgba(255, 255, 255, 0.3)" />
    <circle cx="950" cy="250" r="1" fill="rgba(255, 255, 255, 0.2)" />
    <circle cx="400" cy="200" r="1.5" fill="rgba(255, 255, 255, 0.4)" />
  </svg>
</div>

<style>
  .starfield {
    position: fixed;
    inset: 0;
    z-index: -1;
    width: 100%;
    height: 100vh;
    background: radial-gradient(ellipse at 50% 30%, rgba(78, 103, 255, 0.15) 0%, transparent 40%),
                radial-gradient(ellipse at 20% 60%, rgba(139, 92, 246, 0.1) 0%, transparent 50%),
                linear-gradient(180deg, #070315 0%, #0a0520 50%, #070315 100%);
    overflow: hidden;
    pointer-events: none;
  }

  .stars-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0.85;
    filter: drop-shadow(0 0 8px rgba(192, 132, 252, 0.3));
    animation: twinkle 4s ease-in-out infinite;
  }

  @keyframes twinkle {
    0%, 100% { opacity: 0.85; filter: drop-shadow(0 0 8px rgba(192, 132, 252, 0.3)); }
    50% { opacity: 0.95; filter: drop-shadow(0 0 16px rgba(192, 132, 252, 0.5)); }
  }
</style>
