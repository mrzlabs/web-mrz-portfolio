<script>
  function initBotComponent() {
    const sig = document.querySelector('.mrz-signature');
    if (!sig) return;
    const bot = sig.querySelector('.mrz-bot');
    const map = sig.querySelector('.mrz-build-map');
    if (!bot || !map) return;

    const nds = [...map.querySelectorAll('.nd')];
    const lns = [...map.querySelectorAll('.ln')];
    const routes = [...map.querySelectorAll('.net-routes path')];
    const tgs = [
      { x: '-4vw', y: '-18px' },
      { x: '12vw', y: '-72px' },
      { x: '28vw', y: '-20px' },
      { x: '44vw', y: '-96px' },
      { x: '63vw', y: '-32px' },
      { x: '82vw', y: '-76px' },
      { x: '94vw', y: '-160px' },
      { x: '48vw', y: '-220px' },
      { x: '8vw', y: '-185px' },
    ];

    let idx = 0;
    let tmr = null;
    let act = false;
    let lhp = 0;

    function setPos(t) {
      bot.style.setProperty('--bx', t.x);
      bot.style.setProperty('--by', t.y);
    }

    function reset() {
      nds.forEach((n) => n.classList.remove('on'));
      lns.forEach((l) => l.classList.remove('on'));
      routes.forEach((r) => r.classList.remove('on'));
    }

    function openBuilt() {
      const toggle = sig.querySelector('[data-built-toggle]');
      const panel = sig.querySelector('[data-built-panel]');
      sig.classList.add('is-open');
      toggle?.setAttribute('aria-expanded', 'true');
      panel?.setAttribute('aria-hidden', 'false');
    }

    function step() {
      if (!act) return;
      const next = Math.floor(Math.random() * tgs.length);
      idx = next === idx ? (next + 3) % tgs.length : next;
      setPos(tgs[idx]);
      setTimeout(() => {
        if (!act) return;
        const route = routes[Math.floor(Math.random() * routes.length)];
        if (route) {
          route.classList.remove('on');
          void route.getBoundingClientRect();
          route.classList.add('on');
        }
        tmr = setTimeout(step, 2200 + Math.random() * 2100);
      }, 900);
    }

    function start() {
      if (act) return;
      act = true;
      idx = 0;
      reset();
      step();
    }

    function stop() {
      act = false;
      if (tmr) {
        clearTimeout(tmr);
        tmr = null;
      }
      bot.style.removeProperty('--bx');
      bot.style.removeProperty('--by');
      reset();
    }

    const io = new IntersectionObserver((es) => {
      es.forEach((e) => (e.isIntersecting ? start() : stop()));
    }, { threshold: 0.3 });
    io.observe(sig);

    function hop() {
      const t = Date.now();
      if (t - lhp < 480) return;
      lhp = t;
      bot.classList.add('hop');
      setTimeout(() => bot.classList.remove('hop'), 440);
    }

    window.addEventListener('pointermove', (event) => {
      const r = bot.getBoundingClientRect();
      if (!r.width) return;
      const d = Math.hypot(event.clientX - r.left - r.width / 2, event.clientY - r.top - r.height / 2);
      if (d < 150) hop();
    }, { passive: true });

    bot.addEventListener('click', openBuilt);

    // Toggle buttons
    document.querySelectorAll('[data-built-toggle]').forEach((button) => {
      button.addEventListener('click', () => {
        const sign = button.closest('.mrz-signature');
        sign?.classList.add('is-open');
        button.setAttribute('aria-expanded', 'true');
        sign?.querySelector('[data-built-panel]')?.setAttribute('aria-hidden', 'false');
      });
    });

    document.querySelectorAll('[data-built-close]').forEach((button) => {
      button.addEventListener('click', () => {
        const sign = button.closest('.mrz-signature');
        sign?.classList.remove('is-open');
        sign?.querySelector('[data-built-toggle]')?.setAttribute('aria-expanded', 'false');
        sign?.querySelector('[data-built-panel]')?.setAttribute('aria-hidden', 'true');
      });
    });

    document.querySelectorAll('[data-built-panel]').forEach((panel) => {
      panel.addEventListener('click', (event) => {
        if (event.target === panel) {
          const sign = panel.closest('.mrz-signature');
          sign?.classList.remove('is-open');
          sign?.querySelector('[data-built-toggle]')?.setAttribute('aria-expanded', 'false');
          panel.setAttribute('aria-hidden', 'true');
        }
      });
    });

    // Form submit
    document.querySelectorAll('.built-form').forEach((form) => {
      form.addEventListener('submit', (event) => {
        event.preventDefault();
        const data = new FormData(form);
        const body = `Nombre: ${data.get('nombre')}\nNúmero: ${data.get('telefono')}\nCorreo: ${data.get('correo')}\nComentario: ${data.get('comentario')}`;
        window.location.href = `mailto:andresmartinezr2204@gmail.com?subject=Contacto mrzlabs&body=${encodeURIComponent(body)}`;
      });
    });
  }

  initBotComponent();
</script>

