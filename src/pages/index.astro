---
import Layout from '../layouts/Layout.astro';

const demos = [
  {
    name: 'Top Ink',
    type: 'Landing + campanas',
    live: 'https://amtz-dev.github.io/topink-landing_1/',
    repo: 'https://github.com/amtz-dev/topink-landing_1',
    text: 'Oferta visual, estructura de conversion y base para medicion de Google Ads y Meta.',
    tags: ['HTML', 'CSS', 'JS', 'Ads'],
  },
  {
    name: 'Impermeables Cliente',
    type: 'Web comercial',
    live: 'https://mrzlabs.github.io/web-impermeables-cliente/',
    repo: 'https://github.com/mrzlabs/web-impermeables-cliente',
    text: 'Pagina orientada a captar clientes, explicar servicios y crecer con trafico pago.',
    tags: ['Frontend', 'SEO', 'Copy', 'UX'],
  },
  {
    name: 'Apps Script Starter',
    type: 'Template tecnico',
    live: '',
    repo: 'https://github.com/mrzlabs/tpl-mrz-gas-starter',
    text: 'Base reutilizable para automatizaciones, endpoints ligeros y flujos conectados a datos.',
    tags: ['Apps Script', 'clasp', 'Git', 'API'],
  },
];

const matrix = [
  ['Frontend', 'Astro, HTML, CSS, JavaScript, responsive UI, componentes, accesibilidad base'],
  ['Backend', 'Apps Script Web Apps, APIs REST, Node base, endpoints, validacion de payloads'],
  ['Datos', 'SQL, PostgreSQL, Sheets como backend operativo, normalizacion, KPIs, Looker Studio'],
  ['IA y LLMs', 'prompts, flujos asistidos, clasificacion, soporte, resumentes, copilotos internos'],
  ['Infraestructura', 'GitHub, ramas, despliegues estaticos, Docker base, variables, ambientes'],
  ['Shell', 'PowerShell, comandos Git, automatizacion local, scripts de ejecucion y soporte'],
  ['Crecimiento', 'Google Ads, Meta Ads, landing pages, medicion, embudos, optimizacion'],
  ['CRM', 'pipeline, seguimiento, estados, tickets, handoff, trazabilidad y reportes'],
];

const codeTabs = [
  {
    id: 'js',
    label: 'JavaScript',
    title: 'Interaccion aplicada',
    code: `const lead = {
  source: 'meta_ads',
  stage: 'nuevo',
  score: 82
};

const routeLead = (lead) => {
  if (lead.score >= 80) return 'asesor_comercial';
  if (lead.source === 'google_ads') return 'remarketing';
  return 'nutricion';
};`,
  },
  {
    id: 'sql',
    label: 'SQL',
    title: 'Lectura de negocio',
    code: `select
  campaign,
  count(*) as leads,
  round(avg(score), 2) as avg_score
from crm_leads
where created_at >= current_date - interval '30 days'
group by campaign
order by leads desc;`,
  },
  {
    id: 'sh',
    label: 'Shell',
    title: 'Operacion tecnica',
    code: `git status
npm run build
docker compose up -d
curl -X POST "$WEBHOOK_URL" \\
  -H "Content-Type: application/json" \\
  -d '{"event":"deploy_ok"}'`,
  },
  {
    id: 'llm',
    label: 'LLM',
    title: 'Asistente interno',
    code: `system: Clasifica solicitudes de soporte.
input: "Necesito estado de mi proceso"
output:
{
  "intent": "consulta_estado",
  "priority": "media",
  "handoff": "asesor"
}`,
  },
];
---

<Layout
  title="Andres Martinez | Ingenieria, CRM, LLMs y crecimiento"
  description="Portafolio de Andres Martinez con demos, CRM, LLMs, SQL, Shell, PostgreSQL, frontend, automatizacion y crecimiento digital."
>
  <main class="site">
    <div class="cursor-orb" aria-hidden="true">
      <span>MRZ</span>
    </div>

    <section class="hero" aria-labelledby="hero-title">
      <nav class="nav" aria-label="Navegacion principal">
        <a class="brand" href="/">
          <span>MRZ</span>
          <strong>Labs</strong>
        </a>
        <div class="nav-links">
          <a href="#demos">Demos</a>
          <a href="#toolbox">Toolbox</a>
          <a href="#lab">Lab</a>
          <a href="https://github.com/mrzlabs">GitHub</a>
        </div>
      </nav>

      <div class="hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">Desarrollo corporativo + crecimiento digital</p>
          <h1 id="hero-title">Construyo sistemas, no solo paginas.</h1>
          <p>
            Arquitecto soluciones con frontend, CRM, automatizacion, datos, SQL, PostgreSQL, Shell, APIs, LLMs, dashboards y campanas de adquisicion.
          </p>
        </div>

        <div class="command-card" aria-label="Terminal visual">
          <div class="terminal-head">
            <span></span>
            <span></span>
            <span></span>
          </div>
          <pre><code>mrz@labs:~$ build solution
scope: crm + landing + ads + data
stack: js sql shell postgres llm
status: deployable</code></pre>
        </div>
      </div>
    </section>

    <section class="tabs-shell" aria-label="Vista por pestanas">
      <div class="tabs" role="tablist" aria-label="Secciones principales">
        <button class="tab is-active" type="button" data-tab="vision">Vision</button>
        <button class="tab" type="button" data-tab="engineering">Ingenieria</button>
        <button class="tab" type="button" data-tab="growth">Crecimiento</button>
      </div>
      <div class="tab-panels">
        <article class="tab-panel is-active" data-panel="vision">
          <strong>Capacidad completa</strong>
          <p>Detecto el problema, diseno el flujo, modelo los datos, construyo la interfaz, conecto la automatizacion y dejo medicion para mejorar.</p>
        </article>
        <article class="tab-panel" data-panel="engineering">
          <strong>Criterio senior</strong>
          <p>Trabajo con separacion de ambientes, control de versiones, estructura mantenible, payloads claros, logs utiles, seguridad basica y despliegue repetible.</p>
        </article>
        <article class="tab-panel" data-panel="growth">
          <strong>Negocio medible</strong>
          <p>Una landing sin campana ni medicion queda incompleta. Conecto Google Ads, Meta, formularios, CRM y tablero para tomar decisiones.</p>
        </article>
      </div>
    </section>

    <section id="demos" class="section demos-section" aria-labelledby="demos-title">
      <div class="section-head">
        <p class="eyebrow">Proyectos publicados</p>
        <h2 id="demos-title">Demos visibles</h2>
      </div>

      <div class="demo-grid">
        {demos.map((demo) => (
          <article class="demo-card">
            <div class="demo-frame">
              {demo.live ? (
                <iframe src={demo.live} title={`Demo ${demo.name}`} loading="lazy"></iframe>
              ) : (
                <div class="empty-demo">
                  <strong>Template tecnico</strong>
                  <span>Repositorio sin demo visual. Codigo listo para reutilizar.</span>
                </div>
              )}
            </div>
            <div class="demo-body">
              <span>{demo.type}</span>
              <h3>{demo.name}</h3>
              <p>{demo.text}</p>
              <ul>
                {demo.tags.map((tag) => <li>{tag}</li>)}
              </ul>
              <div class="demo-actions">
                {demo.live && <a href={demo.live}>Ver demo</a>}
                <a href={demo.repo}>Repositorio</a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section id="toolbox" class="section toolbox-section" aria-labelledby="toolbox-title">
      <div class="section-head">
        <p class="eyebrow">Skills & tools</p>
        <h2 id="toolbox-title">Toolbox de ingenieria</h2>
      </div>
      <div class="matrix">
        {matrix.map(([area, value]) => (
          <div class="matrix-row">
            <strong>{area}</strong>
            <span>{value}</span>
          </div>
        ))}
      </div>
    </section>

    <section id="lab" class="section lab-section" aria-labelledby="lab-title">
      <div class="section-head">
        <p class="eyebrow">Mini demos aplicadas</p>
        <h2 id="lab-title">Lenguajes en contexto</h2>
      </div>

      <div class="lab-grid">
        <div class="code-tabs" role="tablist" aria-label="Ejemplos de codigo">
          {codeTabs.map((item, index) => (
            <button class:list={['code-tab', { 'is-active': index === 0 }]} type="button" data-code={item.id}>
              {item.label}
            </button>
          ))}
        </div>
        <div class="code-window">
          {codeTabs.map((item, index) => (
            <article class:list={['code-panel', { 'is-active': index === 0 }]} data-code-panel={item.id}>
              <span>{item.title}</span>
              <pre><code>{item.code}</code></pre>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  const cursor = document.querySelector('.cursor-orb');
  let mouseX = window.innerWidth / 2;
  let mouseY = window.innerHeight / 2;
  let orbX = mouseX;
  let orbY = mouseY;

  window.addEventListener('pointermove', (event) => {
    mouseX = event.clientX;
    mouseY = event.clientY;
  });

  const moveOrb = () => {
    orbX += (mouseX - orbX) * 0.16;
    orbY += (mouseY - orbY) * 0.16;
    if (cursor) {
      cursor.style.transform = `translate3d(${orbX}px, ${orbY}px, 0)`;
    }
    requestAnimationFrame(moveOrb);
  };
  moveOrb();

  document.querySelectorAll('[data-tab]').forEach((button) => {
    button.addEventListener('click', () => {
      const target = button.getAttribute('data-tab');
      document.querySelectorAll('[data-tab]').forEach((item) => item.classList.remove('is-active'));
      document.querySelectorAll('[data-panel]').forEach((item) => item.classList.remove('is-active'));
      button.classList.add('is-active');
      document.querySelector(`[data-panel="${target}"]`)?.classList.add('is-active');
    });
  });

  document.querySelectorAll('[data-code]').forEach((button) => {
    button.addEventListener('click', () => {
      const target = button.getAttribute('data-code');
      document.querySelectorAll('[data-code]').forEach((item) => item.classList.remove('is-active'));
      document.querySelectorAll('[data-code-panel]').forEach((item) => item.classList.remove('is-active'));
      button.classList.add('is-active');
      document.querySelector(`[data-code-panel="${target}"]`)?.classList.add('is-active');
    });
  });
</script>

<style>
  .site {
    min-height: 100vh;
    background: #090b10;
    color: #f4efe5;
    overflow-x: hidden;
  }

  .cursor-orb {
    position: fixed;
    top: -24px;
    left: -24px;
    z-index: 20;
    width: 48px;
    height: 48px;
    display: grid;
    place-items: center;
    border: 1px solid rgba(255, 198, 92, 0.72);
    border-radius: 50%;
    background: rgba(255, 198, 92, 0.16);
    color: #ffc65c;
    font-size: 0.68rem;
    font-weight: 900;
    pointer-events: none;
    mix-blend-mode: screen;
  }

  .hero {
    min-height: 92vh;
    display: flex;
    flex-direction: column;
    padding: 26px clamp(18px, 5vw, 72px) 72px;
    background:
      radial-gradient(circle at 80% 20%, rgba(78, 103, 255, 0.24), transparent 28%),
      linear-gradient(90deg, rgba(9, 11, 16, 0.96), rgba(9, 11, 16, 0.78)),
      repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.08) 0 1px, transparent 1px 96px),
      repeating-linear-gradient(0deg, rgba(255, 255, 255, 0.06) 0 1px, transparent 1px 96px),
      #090b10;
  }

  .nav {
    min-height: 54px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 22px;
  }

  .brand,
  .nav a,
  .demo-actions a {
    color: inherit;
    text-decoration: none;
  }

  .brand {
    display: inline-flex;
    gap: 6px;
    font-weight: 900;
  }

  .brand span,
  .eyebrow,
  .demo-body > span {
    color: #ffc65c;
  }

  .nav-links {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    color: rgba(244, 239, 229, 0.7);
    font-size: 0.92rem;
  }

  .hero-grid {
    flex: 1;
    width: 100%;
    max-width: 1280px;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(300px, 470px);
    align-items: center;
    gap: clamp(32px, 6vw, 96px);
    margin: 0 auto;
  }

  .hero-copy {
    max-width: 980px;
  }

  .eyebrow {
    margin: 0 0 18px;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    margin-bottom: 26px;
    font-size: clamp(3.2rem, 8vw, 8.4rem);
    line-height: 0.86;
    letter-spacing: 0;
  }

  h2 {
    margin: 0;
    font-size: clamp(2rem, 4.8vw, 4.6rem);
    line-height: 0.96;
    letter-spacing: 0;
  }

  h3 {
    margin-bottom: 12px;
    font-size: 1.26rem;
  }

  .hero-copy p:not(.eyebrow) {
    max-width: 760px;
    color: rgba(244, 239, 229, 0.76);
    font-size: clamp(1.08rem, 2vw, 1.38rem);
    line-height: 1.48;
  }

  .command-card {
    padding: 22px;
    background: #f4efe5;
    color: #101219;
    border-radius: 8px;
    box-shadow: 22px 22px 0 #ffc65c;
  }

  .terminal-head {
    display: flex;
    gap: 7px;
    margin-bottom: 18px;
  }

  .terminal-head span {
    width: 10px;
    height: 10px;
    background: #101219;
    border-radius: 50%;
  }

  pre {
    margin: 0;
    overflow: auto;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .tabs-shell,
  .section {
    max-width: 1280px;
    margin: 0 auto;
    padding: 82px clamp(18px, 5vw, 72px);
  }

  .tabs-shell {
    display: grid;
    grid-template-columns: 280px minmax(0, 1fr);
    gap: 18px;
  }

  .tabs,
  .code-tabs {
    display: grid;
    gap: 10px;
  }

  button {
    font: inherit;
  }

  .tab,
  .code-tab {
    min-height: 48px;
    padding: 12px 16px;
    border: 1px solid rgba(244, 239, 229, 0.16);
    background: #141821;
    color: rgba(244, 239, 229, 0.72);
    border-radius: 8px;
    cursor: pointer;
    text-align: left;
  }

  .tab.is-active,
  .code-tab.is-active {
    background: #ffc65c;
    color: #101219;
    font-weight: 900;
  }

  .tab-panels {
    min-height: 220px;
    padding: 30px;
    background: #141821;
    border: 1px solid rgba(244, 239, 229, 0.16);
    border-radius: 8px;
  }

  .tab-panel,
  .code-panel {
    display: none;
  }

  .tab-panel.is-active,
  .code-panel.is-active {
    display: block;
  }

  .tab-panel strong {
    display: block;
    margin-bottom: 18px;
    font-size: clamp(2rem, 4vw, 4rem);
    line-height: 1;
  }

  .tab-panel p {
    max-width: 780px;
    color: rgba(244, 239, 229, 0.74);
    font-size: 1.08rem;
    line-height: 1.55;
  }

  .section-head {
    display: grid;
    grid-template-columns: minmax(180px, 280px) minmax(0, 1fr);
    align-items: end;
    gap: 30px;
    margin-bottom: 40px;
  }

  .demo-grid {
    display: grid;
    gap: 18px;
  }

  .demo-card {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(280px, 0.75fr);
    min-height: 420px;
    overflow: hidden;
    background: #141821;
    border: 1px solid rgba(244, 239, 229, 0.16);
    border-radius: 8px;
  }

  .demo-frame {
    min-height: 420px;
    background: #0d1017;
  }

  .demo-frame iframe {
    width: 100%;
    height: 100%;
    min-height: 420px;
    border: 0;
    background: #fff;
    transform-origin: top left;
  }

  .empty-demo {
    height: 100%;
    display: grid;
    place-content: center;
    gap: 12px;
    padding: 24px;
    text-align: center;
    color: rgba(244, 239, 229, 0.74);
  }

  .demo-body {
    display: flex;
    flex-direction: column;
    padding: 26px;
  }

  .demo-body p,
  .matrix-row span,
  .code-panel span {
    color: rgba(244, 239, 229, 0.72);
    line-height: 1.55;
  }

  .demo-body ul {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: auto 0 24px;
    padding: 0;
    list-style: none;
  }

  .demo-body li {
    padding: 8px 10px;
    background: rgba(255, 198, 92, 0.12);
    border: 1px solid rgba(255, 198, 92, 0.32);
    border-radius: 8px;
    font-size: 0.82rem;
    font-weight: 800;
  }

  .demo-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .demo-actions a {
    min-height: 42px;
    display: inline-flex;
    align-items: center;
    padding: 10px 14px;
    background: #f4efe5;
    color: #101219;
    border-radius: 8px;
    font-weight: 900;
  }

  .toolbox-section {
    border-top: 1px solid rgba(244, 239, 229, 0.14);
    border-bottom: 1px solid rgba(244, 239, 229, 0.14);
  }

  .matrix {
    display: grid;
    border-top: 1px solid rgba(244, 239, 229, 0.18);
  }

  .matrix-row {
    display: grid;
    grid-template-columns: minmax(150px, 260px) minmax(0, 1fr);
    gap: 24px;
    padding: 22px 0;
    border-bottom: 1px solid rgba(244, 239, 229, 0.18);
  }

  .matrix-row strong {
    color: #ffc65c;
  }

  .lab-grid {
    display: grid;
    grid-template-columns: 240px minmax(0, 1fr);
    gap: 18px;
  }

  .code-window {
    min-height: 420px;
    padding: 24px;
    background: #141821;
    border: 1px solid rgba(244, 239, 229, 0.16);
    border-radius: 8px;
  }

  .code-panel span {
    display: block;
    margin-bottom: 20px;
  }

  .code-panel pre {
    padding: 22px;
    background: #090b10;
    border: 1px solid rgba(244, 239, 229, 0.12);
    border-radius: 8px;
  }

  @media (max-width: 980px) {
    .hero-grid,
    .tabs-shell,
    .demo-card,
    .lab-grid {
      grid-template-columns: 1fr;
    }

    .hero {
      min-height: auto;
    }

    .hero-grid {
      padding-top: 68px;
    }

    .command-card {
      box-shadow: 12px 12px 0 #ffc65c;
    }

    .section-head,
    .matrix-row {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 620px) {
    .cursor-orb {
      display: none;
    }

    .nav {
      align-items: flex-start;
      flex-direction: column;
    }

    .nav-links {
      width: 100%;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }

    h1 {
      font-size: 3.2rem;
    }

    .tabs-shell,
    .section {
      padding-top: 60px;
      padding-bottom: 60px;
    }

    .demo-frame,
    .demo-frame iframe {
      min-height: 320px;
    }
  }
</style>
