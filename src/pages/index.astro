---
import Layout from '../layouts/Layout.astro';

const demos = [
  {
    name: 'Top Ink',
    type: 'Landing + campanas',
    live: 'https://amtz-dev.github.io/topink-landing_1/',
    embed: true,
    repo: 'https://github.com/amtz-dev/topink-landing_1',
    text: 'Oferta visual, estructura de conversion y base para medicion de Google Ads y Meta.',
    tags: ['HTML', 'CSS', 'JS', 'Ads'],
  },
  {
    name: 'Impermeables Cliente',
    type: 'Web comercial',
    live: 'https://mrzlabs.github.io/web-impermeables-cliente/',
    embed: true,
    repo: 'https://github.com/mrzlabs/web-impermeables-cliente',
    text: 'Pagina orientada a captar clientes, explicar servicios y crecer con trafico pago.',
    tags: ['Frontend', 'SEO', 'Copy', 'UX'],
  },
  {
    name: 'Seguridad Social SAS',
    type: 'Landing + backend',
    live: 'https://asesoriasas.com',
    embed: false,
    repo: 'https://github.com/mrzlabs/asesorias-seguridad-social',
    text: 'Landing dinamica con frontend estatico, backend Apps Script, datos en Sheets y despliegue en Cloudflare Pages.',
    tags: ['Cloudflare', 'Apps Script', 'Sheets', 'Leads'],
  },
  {
    name: 'Apps Script Starter',
    type: 'Template tecnico',
    live: '',
    embed: false,
    repo: 'https://github.com/mrzlabs/tpl-mrz-gas-starter',
    text: 'Base reutilizable para automatizaciones, endpoints ligeros y flujos conectados a datos.',
    tags: ['Apps Script', 'clasp', 'Git', 'API'],
  },
];

const matrix = [
  ['Frontend', 'Astro, React, Angular, HTML, CSS, JavaScript, responsive UI, dashboards, componentes'],
  ['Workspace', 'Google Workspace, Apps Script, AppSheet, Autocrat, Sheets, Gmail, Drive, formularios'],
  ['Cloud', 'Cloudflare Pages, Workers, GitHub Pages, variables, ambientes, despliegue estatico'],
  ['Backend', 'Apps Script Web Apps, APIs REST, Node base, endpoints, validacion de payloads'],
  ['Datos', 'SQL, PostgreSQL, Sheets como backend operativo, normalizacion, KPIs, Looker Studio'],
  ['IA y LLMs', 'prompts, flujos asistidos, clasificacion, soporte, resumentes, copilotos internos'],
  ['Infraestructura', 'GitHub, ramas, despliegues estaticos, Docker base, variables, ambientes'],
  ['Shell', 'PowerShell, comandos Git, automatizacion local, scripts de ejecucion y soporte'],
  ['Crecimiento', 'Google Ads, Meta Ads, landing pages, medicion, embudos, optimizacion'],
  ['CRM', 'pipeline, seguimiento, estados, tickets, handoff, trazabilidad y reportes'],
];

const stacks = [
  ['JS', 'JavaScript'],
  ['NG', 'Angular'],
  ['RX', 'React'],
  ['GAS', 'Apps Script'],
  ['SQL', 'PostgreSQL'],
  ['APP', 'AppSheet'],
  ['CLD', 'Cloudflare'],
  ['DOC', 'Autocrat'],
  ['LLM', 'LLMs'],
];

const useCases = [
  {
    id: 'crm',
    title: 'CRM comercial',
    text: 'Seguimiento de prospectos, estados, origen de campaña, asesor responsable y cierre.',
    icons: ['React', 'Apps Script', 'Sheets', 'Looker'],
    metrics: [['Leads', '184'], ['Conversión', '18.4%'], ['SLA', '1.6h']],
    rows: [['Meta Ads', '62', '23%', 'Activo'], ['Google Ads', '48', '17%', 'Optimizar'], ['Orgánico', '31', '11%', 'Nutrir']],
  },
  {
    id: 'workspace',
    title: 'Automatización Workspace',
    text: 'Flujos con Apps Script, AppSheet, Autocrat, Gmail, Drive y Sheets como operación central.',
    icons: ['Apps Script', 'AppSheet', 'Autocrat', 'Drive'],
    metrics: [['Procesos', '12'], ['Errores', '0.8%'], ['Ahorro', '38h']],
    rows: [['Contratos PDF', '320', '99.2%', 'Automático'], ['Alertas Gmail', '86', '100%', 'Activo'], ['App móvil', '44', '96%', 'Activo']],
  },
  {
    id: 'growth',
    title: 'Captación y medición',
    text: 'Landing, eventos, campañas, trazabilidad de fuente, dashboards y decisiones por datos.',
    icons: ['Astro', 'GA4', 'Meta Ads', 'SQL'],
    metrics: [['CTR', '6.8%'], ['CPL', '$8.2'], ['ROAS', '3.4x']],
    rows: [['Landing A', '1.284', '7.1%', 'Escalar'], ['Landing B', '942', '5.6%', 'Test'], ['Remarketing', '612', '9.2%', 'Activo']],
  },
];

const codeTabs = [
  {
    id: 'js',
    label: 'JavaScript',
    title: 'Interaccion aplicada',
    code: `const lead = {
  source: 'meta_ads',
  stage: 'nuevo',
  score: 82
};

const routeLead = (lead) => {
  if (lead.score >= 80) return 'asesor_comercial';
  if (lead.source === 'google_ads') return 'remarketing';
  return 'nutricion';
};`,
  },
  {
    id: 'react',
    label: 'React',
    title: 'CRM con estado',
    code: `function LeadBoard({ leads }) {
  const hot = leads.filter((lead) => lead.score >= 80);

  return hot.map((lead) => (
    <LeadCard key={lead.id} lead={lead} />
  ));
}`,
  },
  {
    id: 'ng',
    label: 'Angular',
    title: 'Formulario corporativo',
    code: `leadForm = this.fb.group({
  nombre: ['', Validators.required],
  telefono: ['', [Validators.required]],
  servicio: ['', Validators.required]
});

saveLead() {
  return this.crm.create(this.leadForm.value);
}`,
  },
  {
    id: 'sql',
    label: 'SQL',
    title: 'Lectura de negocio',
    code: `select
  campaign,
  count(*) as leads,
  round(avg(score), 2) as avg_score
from crm_leads
where created_at >= current_date - interval '30 days'
group by campaign
order by leads desc;`,
  },
  {
    id: 'sh',
    label: 'Shell',
    title: 'Operacion tecnica',
    code: `git status
npm run build
docker compose up -d
curl -X POST "$WEBHOOK_URL" \\
  -H "Content-Type: application/json" \\
  -d '{"event":"deploy_ok"}'`,
  },
  {
    id: 'llm',
    label: 'LLM',
    title: 'Asistente interno',
    code: `system: Clasifica solicitudes de soporte.
input: "Necesito estado de mi proceso"
output:
{
  "intent": "consulta_estado",
  "priority": "media",
  "handoff": "asesor"
}`,
  },
];
---

<Layout
  title="mrzlabs | Startup de soluciones digitales, CRM, LLMs y crecimiento"
  description="mrzlabs crea soluciones digitales con demos, CRM, LLMs, SQL, Shell, PostgreSQL, frontend, automatizacion y crecimiento digital."
>
  <main class="site">
    <div class="cursor-orb" aria-hidden="true">
      <span>MRZ</span>
    </div>

    <section class="hero" aria-labelledby="hero-title">
      <nav class="nav" aria-label="Navegacion principal">
        <a class="brand" href="/">
          <span>MRZ</span>
          <strong>Labs</strong>
        </a>
        <div class="nav-links">
          <a href="#soluciones">Soluciones</a>
          <a href="#demos">Demos</a>
          <a href="#toolbox">Toolbox</a>
          <a href="#lab">Lab</a>
          <a href="https://github.com/mrzlabs">GitHub</a>
        </div>
      </nav>

      <div class="hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">Startup de soluciones digitales + crecimiento corporativo</p>
          <h1 id="hero-title">mrzlabs diseña sistemas que convierten operación en crecimiento.</h1>
          <p>
            Creamos frontend, CRM, automatizacion, datos, SQL, PostgreSQL, Shell, APIs, LLMs, dashboards y campanas de adquisicion para empresas que necesitan avanzar con estructura.
          </p>
        </div>

        <div class="command-card" aria-label="Terminal visual">
          <div class="terminal-head">
            <span></span>
            <span></span>
            <span></span>
          </div>
          <pre><code>mrz@labs:~$ build solution
scope: crm + landing + ads + data
stack: js sql shell postgres llm
status: deployable</code></pre>
        </div>
      </div>
    </section>

    <section id="soluciones" class="section solution-section" aria-labelledby="solutions-title">
      <div class="section-head">
        <p class="eyebrow">Modelos de uso</p>
        <h2 id="solutions-title">Soluciones con métricas visibles</h2>
      </div>

      <div class="stack-strip" aria-label="Lenguajes y herramientas">
        {stacks.map(([abbr, name]) => (
          <div class="stack-pill">
            <b>{abbr}</b>
            <span>{name}</span>
          </div>
        ))}
      </div>

      <div class="solution-grid">
        <div class="use-case-list">
          {useCases.map((item, index) => (
            <button class:list={['use-case', { 'is-active': index === 0 }]} type="button" data-case={item.id}>
              <strong>{item.title}</strong>
              <span>{item.text}</span>
              <small>{item.icons.join(' + ')}</small>
            </button>
          ))}
        </div>

        <div class="dashboard-mock">
          {useCases.map((item, index) => (
            <article class:list={['dashboard-panel', { 'is-active': index === 0 }]} data-case-panel={item.id}>
              <div class="dash-head">
                <div>
                  <span>Dashboard</span>
                  <h3>{item.title}</h3>
                </div>
                <b>LIVE</b>
              </div>
              <div class="dash-kpis">
                {item.metrics.map(([label, value]) => (
                  <div>
                    <span>{label}</span>
                    <strong>{value}</strong>
                  </div>
                ))}
              </div>
              <div class="dash-table">
                <div class="dash-row head">
                  <span>Canal</span>
                  <span>Volumen</span>
                  <span>Rendimiento</span>
                  <span>Estado</span>
                </div>
                {item.rows.map((row) => (
                  <div class="dash-row">
                    {row.map((cell) => <span>{cell}</span>)}
                  </div>
                ))}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="tabs-shell" aria-label="Vista por pestanas">
      <div class="tabs" role="tablist" aria-label="Secciones principales">
        <button class="tab is-active" type="button" data-tab="vision">Vision</button>
        <button class="tab" type="button" data-tab="engineering">Ingenieria</button>
        <button class="tab" type="button" data-tab="growth">Crecimiento</button>
      </div>
      <div class="tab-panels">
        <article class="tab-panel is-active" data-panel="vision">
          <strong>Capacidad completa</strong>
          <p>Detecto el problema, diseno el flujo, modelo los datos, construyo la interfaz, conecto la automatizacion y dejo medicion para mejorar.</p>
        </article>
        <article class="tab-panel" data-panel="engineering">
          <strong>Criterio senior</strong>
          <p>Trabajo con separacion de ambientes, control de versiones, estructura mantenible, payloads claros, logs utiles, seguridad basica y despliegue repetible.</p>
        </article>
        <article class="tab-panel" data-panel="growth">
          <strong>Negocio medible</strong>
          <p>Una landing sin campana ni medicion queda incompleta. Conecto Google Ads, Meta, formularios, CRM y tablero para tomar decisiones.</p>
        </article>
      </div>
    </section>

    <section id="demos" class="section demos-section" aria-labelledby="demos-title">
      <div class="section-head">
        <p class="eyebrow">Proyectos publicados</p>
        <h2 id="demos-title">Demos visibles</h2>
      </div>

      <div class="demo-grid">
        {demos.map((demo) => (
          <article class="demo-card">
            <div class="demo-frame">
              {demo.live && demo.embed ? (
                <iframe src={demo.live} title={`Demo ${demo.name}`} loading="lazy"></iframe>
              ) : (
                <div class:list={['empty-demo', { 'site-preview': demo.live }]}>
                  <strong>{demo.live ? demo.name : 'Template tecnico'}</strong>
                  <span>
                    {demo.live
                      ? 'Vista externa protegida. Abre la demo publica desde el boton.'
                      : 'Repositorio sin demo visual. Codigo listo para reutilizar.'}
                  </span>
                  {demo.live && (
                    <div class="preview-bars" aria-hidden="true">
                      <i></i>
                      <i></i>
                      <i></i>
                    </div>
                  )}
                </div>
              )}
            </div>
            <div class="demo-body">
              <span>{demo.type}</span>
              <h3>{demo.name}</h3>
              <p>{demo.text}</p>
              <ul>
                {demo.tags.map((tag) => <li>{tag}</li>)}
              </ul>
              <div class="demo-actions">
                {demo.live && <a href={demo.live} target="_blank" rel="noreferrer">Ver demo</a>}
                <a href={demo.repo} target="_blank" rel="noreferrer">Repositorio</a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section id="toolbox" class="section toolbox-section" aria-labelledby="toolbox-title">
      <div class="section-head">
        <p class="eyebrow">Skills & tools</p>
        <h2 id="toolbox-title">Toolbox de ingenieria</h2>
      </div>
      <div class="matrix">
        {matrix.map(([area, value]) => (
          <div class="matrix-row">
            <strong>{area}</strong>
            <span>{value}</span>
          </div>
        ))}
      </div>
    </section>

    <section id="lab" class="section lab-section" aria-labelledby="lab-title">
      <div class="section-head">
        <p class="eyebrow">Mini demos aplicadas</p>
        <h2 id="lab-title">Lenguajes en contexto</h2>
      </div>

      <div class="lab-grid">
        <div class="code-tabs" role="tablist" aria-label="Ejemplos de codigo">
          {codeTabs.map((item, index) => (
            <button class:list={['code-tab', { 'is-active': index === 0 }]} type="button" data-code={item.id}>
              {item.label}
            </button>
          ))}
        </div>
        <div class="code-window">
          {codeTabs.map((item, index) => (
            <article class:list={['code-panel', { 'is-active': index === 0 }]} data-code-panel={item.id}>
              <span>{item.title}</span>
              <pre><code>{item.code}</code></pre>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="mrz-signature" aria-labelledby="built-title">
      <div class="mrz-bot" aria-hidden="true">
        <span></span>
        <i></i>
      </div>
      <div class="mrz-sign-inner">
        <h2 id="built-title"><span>mrz</span><b>labs</b></h2>
        <button class="built-toggle" type="button" data-built-toggle>Built by mrzlabs</button>
        <p>Infraestructura digital para captación de leads, automatización operativa y medición de crecimiento.</p>
        <div class="built-panel" data-built-panel>
          <div>
            <strong>Propuesta de valor</strong>
            <p>Diseño soluciones con Google Workspace, Apps Script, AppSheet, Cloud, CRM, datos y automatización para convertir procesos manuales en sistemas medibles.</p>
            <a href="https://github.com/mrzlabs" target="_blank" rel="noreferrer">GitHub mrzlabs</a>
          </div>
          <form class="built-form">
            <input name="nombre" placeholder="Nombre" required />
            <input name="telefono" placeholder="Número" required />
            <input name="correo" type="email" placeholder="Correo" />
            <textarea name="comentario" placeholder="Comentario"></textarea>
            <button type="submit">Enviar contacto</button>
          </form>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  const cursor = document.querySelector('.cursor-orb');
  let mouseX = window.innerWidth / 2;
  let mouseY = window.innerHeight / 2;
  let orbX = mouseX;
  let orbY = mouseY;

  window.addEventListener('pointermove', (event) => {
    mouseX = event.clientX;
    mouseY = event.clientY;
  });

  const moveOrb = () => {
    orbX += (mouseX - orbX) * 0.16;
    orbY += (mouseY - orbY) * 0.16;
    if (cursor) {
      cursor.style.transform = `translate3d(${orbX}px, ${orbY}px, 0)`;
    }
    requestAnimationFrame(moveOrb);
  };
  moveOrb();

  document.querySelectorAll('[data-tab]').forEach((button) => {
    button.addEventListener('click', () => {
      const target = button.getAttribute('data-tab');
      document.querySelectorAll('[data-tab]').forEach((item) => item.classList.remove('is-active'));
      document.querySelectorAll('[data-panel]').forEach((item) => item.classList.remove('is-active'));
      button.classList.add('is-active');
      document.querySelector(`[data-panel="${target}"]`)?.classList.add('is-active');
    });
  });

  document.querySelectorAll('[data-code]').forEach((button) => {
    button.addEventListener('click', () => {
      const target = button.getAttribute('data-code');
      document.querySelectorAll('[data-code]').forEach((item) => item.classList.remove('is-active'));
      document.querySelectorAll('[data-code-panel]').forEach((item) => item.classList.remove('is-active'));
      button.classList.add('is-active');
      document.querySelector(`[data-code-panel="${target}"]`)?.classList.add('is-active');
    });
  });

  document.querySelectorAll('[data-case]').forEach((button) => {
    button.addEventListener('click', () => {
      const target = button.getAttribute('data-case');
      document.querySelectorAll('[data-case]').forEach((item) => item.classList.remove('is-active'));
      document.querySelectorAll('[data-case-panel]').forEach((item) => item.classList.remove('is-active'));
      button.classList.add('is-active');
      document.querySelector(`[data-case-panel="${target}"]`)?.classList.add('is-active');
    });
  });

  document.querySelectorAll('[data-built-toggle]').forEach((button) => {
    button.addEventListener('click', () => {
      button.closest('.mrz-signature')?.classList.toggle('is-open');
    });
  });

  document.querySelectorAll('.built-form').forEach((form) => {
    form.addEventListener('submit', (event) => {
      event.preventDefault();
      const data = new FormData(form);
      const body = `Nombre: ${data.get('nombre')}\nNúmero: ${data.get('telefono')}\nCorreo: ${data.get('correo')}\nComentario: ${data.get('comentario')}`;
      window.location.href = `mailto:andresmartinezr2204@gmail.com?subject=Contacto mrzlabs&body=${encodeURIComponent(body)}`;
    });
  });
</script>

<style>
  .site {
    min-height: 100vh;
    background: #090b10;
    color: #f4efe5;
    overflow-x: hidden;
  }

  .cursor-orb {
    position: fixed;
    top: -24px;
    left: -24px;
    z-index: 20;
    width: 48px;
    height: 48px;
    display: grid;
    place-items: center;
    border: 1px solid rgba(255, 198, 92, 0.72);
    border-radius: 50%;
    background: rgba(255, 198, 92, 0.16);
    color: #ffc65c;
    font-size: 0.68rem;
    font-weight: 900;
    pointer-events: none;
    mix-blend-mode: screen;
  }

  .hero {
    min-height: 92vh;
    display: flex;
    flex-direction: column;
    padding: 26px clamp(18px, 5vw, 72px) 72px;
    background:
      radial-gradient(circle at 80% 20%, rgba(78, 103, 255, 0.24), transparent 28%),
      linear-gradient(90deg, rgba(9, 11, 16, 0.96), rgba(9, 11, 16, 0.78)),
      repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.08) 0 1px, transparent 1px 96px),
      repeating-linear-gradient(0deg, rgba(255, 255, 255, 0.06) 0 1px, transparent 1px 96px),
      #090b10;
  }

  .nav {
    min-height: 54px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 22px;
  }

  .brand,
  .nav a,
  .demo-actions a {
    color: inherit;
    text-decoration: none;
  }

  .brand {
    display: inline-flex;
    gap: 6px;
    font-weight: 900;
  }

  .brand span,
  .eyebrow,
  .demo-body > span {
    color: #ffc65c;
  }

  .nav-links {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    color: rgba(244, 239, 229, 0.7);
    font-size: 0.92rem;
  }

  .hero-grid {
    flex: 1;
    width: 100%;
    max-width: 1280px;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(300px, 470px);
    align-items: center;
    gap: clamp(32px, 6vw, 96px);
    margin: 0 auto;
  }

  .hero-copy {
    max-width: 980px;
  }

  .eyebrow {
    margin: 0 0 18px;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    margin-bottom: 26px;
    font-size: clamp(3.2rem, 8vw, 8.4rem);
    line-height: 0.86;
    letter-spacing: 0;
  }

  h2 {
    margin: 0;
    font-size: clamp(2rem, 4.8vw, 4.6rem);
    line-height: 0.96;
    letter-spacing: 0;
  }

  h3 {
    margin-bottom: 12px;
    font-size: 1.26rem;
  }

  .hero-copy p:not(.eyebrow) {
    max-width: 760px;
    color: rgba(244, 239, 229, 0.76);
    font-size: clamp(1.08rem, 2vw, 1.38rem);
    line-height: 1.48;
  }

  .command-card {
    padding: 22px;
    background: #f4efe5;
    color: #101219;
    border-radius: 8px;
    box-shadow: 22px 22px 0 #ffc65c;
  }

  .terminal-head {
    display: flex;
    gap: 7px;
    margin-bottom: 18px;
  }

  .terminal-head span {
    width: 10px;
    height: 10px;
    background: #101219;
    border-radius: 50%;
  }

  pre {
    margin: 0;
    overflow: auto;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .tabs-shell,
  .section {
    max-width: 1280px;
    margin: 0 auto;
    padding: 82px clamp(18px, 5vw, 72px);
  }

  .stack-strip {
    display: grid;
    grid-template-columns: repeat(9, minmax(82px, 1fr));
    gap: 10px;
    margin-bottom: 20px;
  }

  .stack-pill {
    min-height: 86px;
    display: grid;
    place-items: center;
    gap: 4px;
    padding: 12px;
    background: #f4efe5;
    color: #101219;
    border-radius: 8px;
    text-align: center;
  }

  .stack-pill b {
    color: #ff6b00;
    font-size: 1.1rem;
  }

  .stack-pill span {
    font-size: 0.72rem;
    font-weight: 900;
  }

  .solution-grid {
    display: grid;
    grid-template-columns: 360px minmax(0, 1fr);
    gap: 18px;
  }

  .use-case-list {
    display: grid;
    gap: 12px;
  }

  .use-case {
    padding: 18px;
    border: 1px solid rgba(244, 239, 229, 0.16);
    border-radius: 8px;
    background: #141821;
    color: rgba(244, 239, 229, 0.74);
    text-align: left;
    cursor: pointer;
  }

  .use-case strong,
  .use-case span,
